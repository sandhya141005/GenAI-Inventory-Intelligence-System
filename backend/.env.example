PROJECT_NAME="GenAI Inventory Intelligence API"
ENVIRONMENT=development
API_PREFIX=/api

DATABASE_URL=postgresql://inventory:inventory@localhost:5432/inventory_copilot
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Use groq as primary. Set LLM_PROVIDER=openai for OpenAI.
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MEMBER3_ANALYTICS_BASE_URL=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
